{
  "id": "SDK-ERR-013",
  "description": "Partial reveal keeps the request-level result successful while per-view decode failures still reach the affected view's error callback.",
  "input": {
    "operation": "simulatePartialRevealRequestResult",
    "requestResult": {
      "code": 200
    },
    "views": [
      {
        "viewId": "text-success",
        "kind": "label",
        "contentPath": "card.last4",
        "decodeResult": {
          "outcome": "success",
          "value": "4242"
        }
      },
      {
        "viewId": "image-failure",
        "kind": "image",
        "contentPath": "card.image",
        "decodeResult": {
          "outcome": "failure",
          "error": {
            "code": 1405,
            "type": "invalidBase64Data",
            "message": "Payload is not valid base64 data"
          }
        }
      }
    ]
  },
  "expected": {
    "outcome": "success",
    "requestResult": {
      "code": 200
    },
    "perView": [
      {
        "viewId": "text-success",
        "errorCallbackFired": false
      },
      {
        "viewId": "image-failure",
        "errorCallbackFired": true,
        "error": {
          "code": 1405,
          "type": "invalidBase64Data",
          "message": "Payload is not valid base64 data"
        }
      }
    ],
    "warningLogCount": 1
  }
}
