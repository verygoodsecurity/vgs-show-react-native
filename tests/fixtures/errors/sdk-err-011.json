{
  "id": "SDK-ERR-011",
  "description": "Calling `request()` with invalid reveal configuration rejects synchronously with `invalidConfigurationURL` before any HTTP attempt.",
  "input": {
    "operation": "requestWithInvalidConfiguration",
    "cases": [
      {
        "label": "emptyTenantId",
        "vgsShow": {
          "id": "",
          "environment": "sandbox"
        },
        "request": {
          "path": "/post"
        }
      },
      {
        "label": "invalidRegionalEnvironment",
        "vgsShow": {
          "id": "tenant123",
          "environment": "live/"
        },
        "request": {
          "path": "/post"
        }
      }
    ]
  },
  "expected": {
    "outcome": "allFailure",
    "perCase": [
      {
        "requestDispatched": false,
        "error": {
          "code": 1480,
          "type": "invalidConfigurationURL",
          "message": "VGS configuration URL is not valid"
        }
      },
      {
        "requestDispatched": false,
        "error": {
          "code": 1480,
          "type": "invalidConfigurationURL",
          "message": "VGS configuration URL is not valid"
        }
      }
    ]
  }
}
