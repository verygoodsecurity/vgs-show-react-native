        "payload": {
          "key": {
            "$date": "2026-04-24T00:00:00.000Z"
          }
        }
      },
      {
        "label": "typed-array",
        "payload": {
          "key": {
            "$uint8Array": [
              1,
              2,
              3
            ]
          }
        }
      },
      {
        "label": "map",
        "payload": {
          "key": {
            "$map": [
              [
                "a",
                1
              ]
            ]
          }
        }
      },
      {
        "label": "set",
        "payload": {
          "key": {
            "$set": [
              1
            ]
          }
        }
      },
      {
        "label": "nan",
        "payload": {
          "key": {
            "$nan": true
          }
        }
      },
      {
        "label": "infinity",
        "payload": {
          "key": {
            "$infinity": true
          }
        }
      },
      {
        "label": "array-top-level",
        "payload": [
          1,
          2,
          3
        ]
      }
    ]
  },
  "expected": {
