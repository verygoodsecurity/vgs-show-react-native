{
  "id": "SDK-NET-018",
  "description": "Extended JSON payload validation reject table required by OPEN_QUESTIONS.md #14. Non-JSON JS values reject with invalidJSONPayload before HTTP dispatch.",
  "input": {
    "operation": "validateJsonPayloadCases",
    "cases": [
      {
        "label": "undefined",
        "payload": {
          "key": {
            "$undefined": true
          }
        }
      },
      {
        "label": "function",
        "payload": {
          "key": {
            "$function": true
          }
        }
      },
      {
        "label": "symbol",
        "payload": {
          "key": {
            "$symbol": "x"
          }
        }
      },
      {
