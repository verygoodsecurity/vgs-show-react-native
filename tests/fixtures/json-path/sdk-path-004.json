{
  "id": "SDK-PATH-004",
  "description": "Dot-notation contentPaths with invalid keys / invalid separator characters do not resolve (resolver returns undefined, which the decoder surfaces as fieldNotFound). Each wrong key paired with the JSON fixture of matching depth from validNestedJSON_{1..4}.json.",
  "input": {
    "operation": "resolveJsonPath",
    "cases": [
      {
        "contentPath": "card_typ",
        "json": {
          "card_type": "VISA"
        }
      },
      {
        "contentPath": "json.card-type",
        "json": {
          "json": {
            "card_type": "VISA"
          }
        }
      },
      {
        "contentPath": "json.card_data/card_type",
        "json": {
          "json": {
            "card_data": {
              "card_type": "VISA"
            }
          }
        }
      },
      {
        "contentPath": "json.card_data-data.card_type",
        "json": {
          "json": {
            "card_data": {
              "data": {
                "card_type": "VISA"
              },
              "card_type2": "Mastercard",
              "card_TYPE": "Mastercard-2"
            }
          }
        }
      }
    ]
  },
  "expected": {
    "outcome": "resolveReturnsUndefined",
    "allCasesFail": true,
    "perCase": [
      {
        "resolved": null
      },
      {
        "resolved": null
      },
      {
        "resolved": null
      },
      {
        "resolved": null
      }
    ]
  }
}
