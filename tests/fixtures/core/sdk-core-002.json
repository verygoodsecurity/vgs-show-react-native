{
  "id": "SDK-CORE-002",
  "description": "A label subscribe/unsubscribe sequence updates `subscribedLabels` and `subscribedViews` counts, silently ignores a duplicate subscribe of the same instance, and `unsubscribeAllViews()` clears both collections.",
  "input": {
    "operation": "runVgsShowSubscriptionSequence",
    "viewKind": "label",
    "operations": [
      {
        "action": "subscribe",
        "viewId": "label1"
      },
      {
        "action": "subscribe",
        "viewId": "label2"
      },
      {
        "action": "subscribe",
        "viewId": "label2"
      },
      {
        "action": "unsubscribe",
        "viewId": "label2"
      },
      {
        "action": "unsubscribe",
        "viewId": "label1"
      },
      {
        "action": "subscribe",
        "viewId": "label1"
      },
      {
        "action": "subscribe",
        "viewId": "label2"
      },
      {
        "action": "unsubscribeAllViews"
      }
    ]
  },
  "expected": {
    "outcome": "success",
    "perStep": [
      {
        "afterOperation": 0,
        "subscribedLabels": 0,
        "subscribedViews": 0
      },
      {
        "afterOperation": 1,
        "subscribedLabels": 1,
        "subscribedViews": 1
      },
      {
        "afterOperation": 2,
        "subscribedLabels": 2,
        "subscribedViews": 2
      },
      {
        "afterOperation": 3,
        "subscribedLabels": 2,
        "subscribedViews": 2
      },
      {
        "afterOperation": 4,
        "subscribedLabels": 1,
        "subscribedViews": 1
      },
      {
        "afterOperation": 5,
        "subscribedLabels": 0,
        "subscribedViews": 0
      },
      {
        "afterOperation": 7,
        "subscribedLabels": 2,
        "subscribedViews": 2
      },
      {
        "afterOperation": 8,
        "subscribedLabels": 0,
        "subscribedViews": 0
      }
    ]
  }
}
