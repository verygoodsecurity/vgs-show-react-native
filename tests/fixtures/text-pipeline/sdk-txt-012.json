{
  "id": "SDK-TXT-012",
  "description": "Adding a transformation regex applies the provided template to the raw card number; different templates produce the expected insertion-order formatting result.",
  "input": {
    "operation": "applySingleTransformationRegex",
    "rawText": "4111111111111111",
    "pattern": "(\\d{4})(\\d{4})(\\d{4})(\\d{4})",
    "cases": [
      {
        "template": "$1-$2-$3-$4"
      },
      {
        "template": "$1 $2 $3 $4"
      },
      {
        "template": "$1/$2/$3/$4"
      }
    ]
  },
  "expected": {
    "outcome": "success",
    "perCase": [
      {
        "transformedText": "4111-1111-1111-1111"
      },
      {
        "transformedText": "4111 1111 1111 1111"
      },
      {
        "transformedText": "4111/1111/1111/1111"
      }
    ]
  }
}
