{
  "id": "SDK-TXT-011",
  "description": "Text-range validation on the formatted card string accepts nil bounds, accepts `end` values beyond the string length, and rejects negative indices or ranges where `start > end`.",
  "input": {
    "operation": "isTextRangeValid",
    "text": "4111-1111-1111-1111",
    "cases": [
      {
        "range": {
          "start": null,
          "end": null
        }
      },
      {
        "range": {
          "start": 0,
          "end": null
        }
      },
      {
        "range": {
          "start": null,
          "end": 4
        }
      },
      {
        "range": {
          "start": 5,
          "end": 4
        }
      },
      {
        "range": {
          "start": 100,
          "end": 4
        }
      },
      {
        "range": {
          "start": -1,
          "end": 4
        }
      },
      {
        "range": {
          "start": 1,
          "end": -4
        }
      },
      {
        "range": {
          "start": 0,
          "end": 100
        }
      },
      {
        "range": {
          "start": 3,
          "end": 3
        }
      }
    ]
  },
  "expected": {
    "outcome": "success",
    "perCase": [
      {
        "isValid": true
      },
      {
        "isValid": true
      },
      {
        "isValid": true
      },
      {
        "isValid": false
      },
      {
        "isValid": false
      },
      {
        "isValid": false
      },
      {
        "isValid": false
      },
      {
        "isValid": true
      },
      {
        "isValid": true
      }
    ]
  }
}
