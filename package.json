{
  "name": "@vgs/show-react-native",
  "version": "1.0.0",
  "description": "VGS Show React Native SDK",
  "license": "MIT",
  "type": "module",
  "main": "./lib/index.js",
  "react-native": "./lib/index.js",
  "browser": "./lib/web-unsupported.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "browser": "./lib/web-unsupported.js",
      "react-native": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "src"
  ],
    "repository": {
    "type": "git",
    "url": "git+https://github.com/verygoodsecurity/vgs-show-react-native.git"
  },
  "homepage": "https://github.com/verygoodsecurity/vgs-show-react-native#readme",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf lib",
    "docs": "typedoc",
    "prepare": "npm run build",
    "release:check": "npm ci && npm run build && npm run typecheck && npm test -- --ci && npm audit --omit=dev && npm pack --dry-run",
    "release:dry-run": "npm publish --dry-run --access public",
    "test": "npm run build && NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "packageManager": "npm@11.6.0",
  "devDependencies": {
    "jest": "^30.1.3",
    "pre-commit": "^1.2.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "react-native-blob-util": "^0.24.7",
    "react-native-pdf": "^7.0.4"
  },
  "overrides": {
    "pre-commit": {
      "cross-spawn": "6.0.6"
    }
  },
  "peerDependencies": {
    "react": ">=19.1.0",
    "react-native": ">=0.81.4"
  }
}
